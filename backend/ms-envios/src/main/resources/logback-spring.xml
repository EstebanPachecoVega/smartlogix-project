<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="CONSOLE_PATTERN" source="logging.pattern.console"
        defaultValue='{"timestamp":"%d{ISO8601}","level":"%p","correlationId":"%X{correlationId}","message":"%m","logger":"%c"}%n'/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <springProfile name="docker">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <batchMaxItems>100</batchMaxItems>
            <batchMaxTimeoutMs>5000</batchMaxTimeoutMs>
            <http>
                <url>http://loki:3100/loki/api/v1/push</url>
                <requestTimeoutMs>5000</requestTimeoutMs>
            </http>
            <format>
                <label>
                    <pattern>app=ms-envios,host=${HOSTNAME:-unknown}</pattern>
                </label>
                <message>
                    <pattern>{"timestamp":"%d{ISO8601}","level":"%p","traceId":"%X{traceId:-}","spanId":"%X{spanId:-}","message":"%m","logger":"%c"}</pattern>
                </message>
            </format>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

    <springProfile name="!docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
